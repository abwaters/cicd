{
  "app": "ccfw",
  "account": "907688428238",
  "region": "us-east-1",
  "environment": {
    "DDB_ADS_TABLE_NAME": "!ImportValue ccfw-ads-table",
    "DDB_APPOINTMENTS_TABLE_NAME": "!ImportValue ccfw-appointments-table",
    "DDB_CONTACTS_TABLE_NAME": "!ImportValue ccfw-contacts-table",
    "DDB_TRANSPONDER_TABLE_NAME": "!ImportValue ccfw-transponder-table",
    "GCAL_CREDENTIALS": "!ParameterStore /ccfw/prod/service/gcal_credentials",
    "GCAL_ID": "!ParameterStore /ccfw/prod/service/gcal_id",
    "TWILIO_ACCOUNT_SID": "!ParameterStore /ccfw/prod/service/twilio_account_sid",
    "TWILIO_AUTH_TOKEN": "!ParameterStore /ccfw/prod/service/twilio_auth_token",
    "TWILIO_CALLBACK_URL": "!ParameterStore /ccfw/prod/service/twilio_callback_url",
    "TWILIO_NOTIFICATION_PHONE_NUMBER": "!ParameterStore /ccfw/prod/service/twilio_notification_phone_number",
    "TWILIO_FROM_PHONE": "!ParameterStore /ccfw/prod/service/twilio_from_phone",
    "SLACK_SIGNING_SECRET": "!ParameterStore /ccfw/prod/service/slack_signing_secret",
    "SLACK_COMMAND_TOPIC": "!ImportValue ccfw-slack-command-topic",
    "SLACK_BOT_TOKEN": "!ParameterStore /ccfw/prod/service/slack_bot_token",
    "SLACK_LOG_CHANNEL": "!ParameterStore /ccfw/prod/service/slack_log_channel"
  },
  "exports": [
    {
      "type": "api",
      "name": "ccfw-ads-api",
      "path": "ads",
      "functions": [
        {"name": "ccfw-ads-function","method": "GET","env": "DDB_ADS_TABLE_NAME"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-appointments-api",
      "path": "appointments",
      "functions": [
        {"name": "ccfw-appointments-function","method": "POST","env": "DDB_APPOINTMENTS_TABLE_NAME,GCAL_CREDENTIALS,GCAL_ID,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_FROM_PHONE,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER"},
        {"name": "ccfw-appointments-delete-function","method": "DELETE","env": "DDB_APPOINTMENTS_TABLE_NAME,GCAL_CREDENTIALS,GCAL_ID,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_FROM_PHONE,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-hours-api",
      "path": "hours",
      "functions": [
        {"name": "ccfw-hours-function","method": "GET","env": "TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_FROM_PHONE,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-search-api",
      "path": "search",
      "functions": [
        {"name": "ccfw-search-function","method": "POST","env": "DDB_APPOINTMENTS_TABLE_NAME,GCAL_CREDENTIALS,GCAL_ID,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_FROM_PHONE,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-contacts-api",
      "path": "contacts",
      "functions": [
        {"name": "ccfw-contacts-function","method": "POST","env": "DDB_CONTACTS_TABLE_NAME"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-slack-api",
      "path": "slack",
      "functions": [
        {"name": "ccfw-slack-dispatch-function","method": "POST","concurrency":0,"env": "SLACK_COMMAND_TOPIC,SLACK_BOT_TOKEN,SLACK_SIGNING_SECRET"},
        {"name": "ccfw-slack-events-function","method": "POST","concurrency":0,"env": "SLACK_COMMAND_TOPIC,SLACK_BOT_TOKEN,SLACK_SIGNING_SECRET"},
        {"name": "ccfw-slack-interactions-function","method": "POST","concurrency":0,"env": "SLACK_COMMAND_TOPIC,SLACK_BOT_TOKEN,SLACK_SIGNING_SECRET"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-sms-api",
      "path": "sms",
      "functions": [
        {"name": "ccfw-sms-function","method": "GET","env": "TWILIO_FROM_PHONE,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER"}
      ]
    },
    {
      "type": "api",
      "name": "ccfw-transponder-api",
      "path": "transponder",
      "functions": [
        {"name": "ccfw-transponder-function","method": "POST","env": "DDB_TRANSPONDER_TABLE_NAME"}
      ]
    },
    {
      "type": "sns",
      "name": "ccfw-slack-command-topic",
      "stages": ["prod"],
      "functions": [
        {"name": "ccfw-slack-command-function","method": "POST","env": "DDB_APPOINTMENTS_TABLE_NAME,SLACK_LOG_CHANNEL,SLACK_COMMAND_TOPIC,SLACK_BOT_TOKEN,SLACK_SIGNING_SECRET,TWILIO_FROM_PHONE,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER,GCAL_CREDENTIALS,GCAL_ID"}
      ]
    },
    {
      "type": "sns",
      "name": "ccfw-slack-command-staging-topic",
      "stages": ["staging"],
      "functions": [
        {"name": "ccfw-slack-command-function","method": "POST","env": "DDB_APPOINTMENTS_TABLE_NAME,SLACK_LOG_CHANNEL,SLACK_COMMAND_TOPIC,SLACK_BOT_TOKEN,SLACK_SIGNING_SECRET,TWILIO_FROM_PHONE,TWILIO_ACCOUNT_SID,TWILIO_AUTH_TOKEN,TWILIO_CALLBACK_URL,TWILIO_NOTIFICATION_PHONE_NUMBER,GCAL_CREDENTIALS,GCAL_ID"}
      ]
    }
  ],
  "stages": [
    {
      "stage": "prod",
      "mapping": {
        "domain": "api.chicagocenterforwomen.com",
        "path": ""
      },
      "environment": {
        "SLACK_COMMAND_TOPIC": "!ImportValue ccfw-slack-command-topic"
      }
    },
    {
      "stage": "staging",
      "mapping": {
        "domain": "api.chicagocenterforwomen.com",
        "path": "staging"
      },
      "environment": {
        "SLACK_COMMAND_TOPIC": "!ImportValue ccfw-slack-command-staging-topic"
      }
    },
    {
      "stage": "tools",
      "mapping": {
        "domain": "api.chicagocenterforwomen.com",
        "path": "tools"
      },
      "environment": {
        "SLACK_COMMAND_TOPIC": "!ImportValue ccfw-slack-command-tools-topic"
      }
    }
  ]
}
