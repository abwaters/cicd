    "@aws-sdk/client-ssm": "^3.1007.0",
    "@aws-sdk/client-sts": "^3.1007.0",
    "ajv": "^8.18.0",
    "twilio": "^5.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
