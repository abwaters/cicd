{
  "name": "@abwaters/cicd",
  "version": "1.0.0",
  "description": "AWS CI/CD deployment tool for Lambda, API Gateway, and SNS",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "cicd": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abwaters/cicd.git"
  },
  "files": [
    "dist/",
    "cicd.schema.json"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "deploy": "node dist/index.js deploy",
    "info": "node dist/index.js info",
    "clean": "node dist/index.js clean",
    "validate": "node dist/index.js validate",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.{js,ts}"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1033.0",
    "@aws-sdk/client-apigatewayv2": "^3.1038.0",
    "@aws-sdk/client-cloudformation": "^3.1033.0",
    "@aws-sdk/client-ecr": "^3.1038.0",
    "@aws-sdk/client-ecs": "^3.1038.0",
    "@aws-sdk/client-lambda": "^3.1038.0",
    "@aws-sdk/client-sns": "^3.1033.0",
    "@aws-sdk/client-ssm": "^3.1038.0",
    "@aws-sdk/client-sts": "^3.1033.0",
    "ajv": "^8.20.0",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
